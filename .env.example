GEMINI_API_KEY=your_gemini_api_key_here

# Telegram bot — required for /webhook/telegram. Get from @BotFather.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Meta WhatsApp Cloud API — optional, only needed for /webhook/whatsapp.
# META_PHONE_NUMBER_ID=
# META_ACCESS_TOKEN=
# META_APP_SECRET=
# META_VERIFY_TOKEN=
